DATABASE_URL=postgresql://postgres:postgres@localhost:5432/workit

NEXTAUTH_SECRET=replace-with-strong-random-secret
NEXTAUTH_URL=http://localhost:3000

# Optional OAuth providers (enabled only when both id+secret are set)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Optional email OTP webhook (falls back to server log output when unset)
EMAIL_OTP_WEBHOOK_URL=
EMAIL_OTP_WEBHOOK_BEARER=

# Hedera + AWS settings used by @workit-poa/auth -> @workit-poa/hedera-kms-wallet
AWS_REGION=us-east-1
HEDERA_NETWORK=testnet

# Preferred operator names used by @workit-poa/hedera-kms-wallet
OPERATOR_ID=
OPERATOR_KEY=
# Optional: force key parsing mode ("ecdsa" | "ed25519" | "der")
OPERATOR_KEY_TYPE=

# Backward-compatible names still supported
HEDERA_OPERATOR_ID=
HEDERA_OPERATOR_KEY=

# Required for secure KMS key creation during managed wallet provisioning
AWS_ACCOUNT_ID=
KMS_KEY_ADMIN_PRINCIPAL_ARN=
KMS_RUNTIME_SIGNER_PRINCIPAL_ARN=

# Optional KMS naming overrides
HEDERA_KMS_ALIAS_PREFIX=alias/workit-user
HEDERA_KMS_KEY_DESCRIPTION_PREFIX=Workit Hedera key for user

# Launchpad UI + sponsored transaction settings
LAUNCHPAD_ADDRESS=
HEDERA_EVM_RPC_URL=
PAYMASTER_OPERATOR_ID=
PAYMASTER_OPERATOR_KEY=
PAYMASTER_MAX_GAS_ALLOWANCE_HBAR=2
LAUNCHPAD_WHBAR_ADDRESS=0x0000000000000000000000000000000000003ad1
LAUNCHPAD_NATIVE_HBAR_RESERVE_HBAR=0.05
