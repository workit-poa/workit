# AWS credentials/region
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Hedera operator (choose one pair)
OPERATOR_ID=0.0.0
OPERATOR_KEY=
# HEDERA_OPERATOR_ID=0.0.0
# HEDERA_OPERATOR_KEY=

# Hedera network
HEDERA_NETWORK=testnet

# New account funding at create time (set 0 to skip)
HEDERA_NEW_ACCOUNT_INITIAL_HBAR=1

# Demo-specific optional values
KMS_KEY_ID=
HEDERA_USER_ACCOUNT_ID=
DEMO_USER_ID=
DEMO_MODE=topic
DEMO_TOPIC_MESSAGE=
DEMO_TRANSFER_TINYBAR=1
DEMO_TRANSFER_TO_ACCOUNT_ID=
