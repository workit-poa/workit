# AWS credentials/region
AWS_REGION=us-east-1
# AWS_DEFAULT_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Required for secure key creation (when KMS_KEY_ID is not provided)
AWS_ACCOUNT_ID=
KMS_KEY_ADMIN_PRINCIPAL_ARN=
KMS_RUNTIME_SIGNER_PRINCIPAL_ARN=
# Local-only escape hatch (not recommended outside local demos)
ALLOW_UNSAFE_KMS_DEFAULT_POLICY=false

# Hedera operator (choose one pair)
OPERATOR_ID=0.0.0
OPERATOR_KEY=
# Optional: force key parsing mode ("ecdsa" | "ed25519" | "der")
OPERATOR_KEY_TYPE=
# HEDERA_OPERATOR_ID=0.0.0
# HEDERA_OPERATOR_KEY=

# Hedera network
HEDERA_NETWORK=testnet

# Optional provisioning defaults
# Used by provisionHederaAccountForUser() when creating a new key.
HEDERA_KMS_ALIAS_PREFIX=alias/workit-user
HEDERA_KMS_KEY_DESCRIPTION_PREFIX=Workit Hedera key for user

# New account funding at create time (demo requires >0 when provisioning new account)
HEDERA_NEW_ACCOUNT_INITIAL_HBAR=1

# Demo-specific optional values
KMS_KEY_ID=
HEDERA_USER_ACCOUNT_ID=
DEMO_USER_ID=
DEMO_MODE=topic
DEMO_TOPIC_MESSAGE=
DEMO_TRANSFER_TINYBAR=1
DEMO_TRANSFER_TO_ACCOUNT_ID=
