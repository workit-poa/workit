{
  "name": "@workit-poa/hedera-kms-wallet",
  "version": "0.2.0",
  "description": "AWS KMS-backed Hedera wallet provisioning and signing utilities.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/workit-poa/workit.git",
    "directory": "libs/hedera-kms-wallet"
  },
  "homepage": "https://github.com/workit-poa/workit/tree/main/libs/hedera-kms-wallet#readme",
  "bugs": {
    "url": "https://github.com/workit-poa/workit/issues"
  },
  "private": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    ".env.example",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "hedera",
    "hashgraph",
    "aws-kms",
    "kms",
    "wallet",
    "signer"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepack": "pnpm run clean && pnpm run lint && pnpm run test && pnpm run build"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "dotenv": "^16.4.5",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@noble/hashes": "^1.7.1",
    "@aws-sdk/client-kms": "^3.900.0",
    "@hashgraph/sdk": "^2.62.0"
  }
}
