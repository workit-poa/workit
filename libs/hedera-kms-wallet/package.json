{
  "name": "@workit/hedera-kms-wallet",
  "version": "0.1.0",
  "private": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepack": "pnpm run clean && pnpm run lint && pnpm run test && pnpm run build",
    "demo:kms-hedera": "tsx src/demo/kms-hedera-demo.ts"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@noble/hashes": "^1.7.1",
    "@aws-sdk/client-kms": "^3.900.0",
    "@hashgraph/sdk": "^2.62.0",
    "dotenv": "^16.4.5"
  }
}
