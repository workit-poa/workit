{
  "name": "@workit-poa/contracts",
  "version": "0.1.0",
  "private": true,
  "description": "Hardhat workspace for Workit smart contracts.",
  "scripts": {
    "build": "hardhat compile",
    "lint": "tsc --noEmit -p tsconfig.json",
    "clean": "hardhat clean",
    "compile": "hardhat compile",
    "test": "hardhat test --network hardhat",
    "test:saucer:testnet": "hardhat test test/CampaignSaucerIntegration --network hederaTestnet",
    "test:local": "hardhat test --network hederaLocal",
    "node": "hardhat node",
    "ping:local": "hardhat hedera:ping --network hederaLocal",
    "console:local": "hardhat console --network hederaLocal",
    "console:testnet": "hardhat console --network hederaTestnet",
    "console:previewnet": "hardhat console --network hederaPreviewnet",
    "console:mainnet": "hardhat console --network hederaMainnet",
    "deploy:local": "hardhat run scripts/deploy.ts --network hederaLocal",
    "deploy:testnet": "hardhat compile && hardhat run scripts/deploy.ts --network hederaTestnet",
    "deploy:previewnet": "hardhat run scripts/deploy.ts --network hederaPreviewnet",
    "deploy:mainnet": "hardhat run scripts/deploy.ts --network hederaMainnet",
    "deploy:saucer:hardhat": "hardhat run scripts/deploy-saucerswap-core.ts --network hardhat",
    "upgrade:core:testnet": "hardhat compile && hardhat run scripts/upgrade-core-contracts.ts --network hederaTestnet",
    "resolve:local": "hardhat run scripts/resolve-campaigns.ts --network hederaLocal",
    "resolve:testnet": "hardhat run scripts/resolve-campaigns.ts --network hederaTestnet",
    "resolve:previewnet": "hardhat run scripts/resolve-campaigns.ts --network hederaPreviewnet",
    "resolve:mainnet": "hardhat run scripts/resolve-campaigns.ts --network hederaMainnet",
    "hcs:local": "tsx scripts/hcs-local.ts",
    "hts:local": "tsx scripts/hts-local.ts"
  },
  "devDependencies": {
    "@hashgraph/system-contracts-forking": "0.1.2",
    "@hashgraph/smart-contracts": "github:hashgraph/hedera-smart-contracts",
    "@openzeppelin/contracts": "^5.0.0",
    "@openzeppelin/contracts-upgradeable": "^5.0.0",
    "@hashgraph/sdk": "^2.62.0",
    "@types/chai": "^4.3.20",
    "bn.js": "5.2.1",
    "chai": "^4.5.0",
    "dotenv": "^16.4.5",
    "hardhat": "2.22.19",
    "prb-math": "2.4.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3",
    "typescript": "^5.7.2",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox": "5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/mocha": ">=9.1.0",
    "@types/node": "^20.0.0",
    "hardhat-gas-reporter": "^1.0.8",
    "solidity-coverage": "^0.8.1",
    "typechain": "^8.3.0"
  }
}
