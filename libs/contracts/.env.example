# Hardhat default network if --network is omitted.
# Supported: hardhat | local | testnet | previewnet | mainnet
HEDERA_NETWORK=local

# One or more deployment keys.
# Option A: one key (with or without 0x)
HEDERA_PRIVATE_KEY=
# Option B: comma-separated keys (optional)
HEDERA_PRIVATE_KEYS=

# Hedera local node endpoints
HEDERA_LOCAL_RPC_URL=http://localhost:7546
HEDERA_LOCAL_WS_URL=ws://localhost:8546
HEDERA_LOCAL_CONSENSUS_ENDPOINT=localhost:50211
HEDERA_LOCAL_MIRROR_GRPC_ENDPOINT=localhost:5600
HEDERA_LOCAL_MIRROR_REST_ENDPOINT=http://localhost:5551

# Local funded accounts (generated automatically by: pnpm hedera:local:keys)
HEDERA_LOCAL_ACCOUNT_ID_1=
HEDERA_LOCAL_PRIVATE_KEY_1=
HEDERA_LOCAL_ACCOUNT_ID_2=
HEDERA_LOCAL_PRIVATE_KEY_2=

# Operator aliases used by SDK helper scripts (HCS/HTS)
HEDERA_OPERATOR_ID=
HEDERA_OPERATOR_KEY=
OPERATOR_ID=
OPERATOR_KEY=

# Optional Hedera public RPC overrides
HEDERA_TESTNET_RPC_URL=https://testnet.hashio.io/api
HEDERA_PREVIEWNET_RPC_URL=https://previewnet.hashio.io/api
HEDERA_MAINNET_RPC_URL=https://mainnet.hashio.io/api

# Optional deploy script configuration
WORK_TOKEN_CREATE_HBAR_TO_SEND=15
GOVERNANCE_NFT_CREATE_HBAR_TO_SEND=15
DEPLOY_GAS_LIMIT=1000000
GOVERNANCE_NFT_MAX_SUPPLY=1000000
GTOKEN_EPOCH_LENGTH_SECONDS=86400
CREATE_GOVERNANCE_NFT=true

# If set, deploy script uses existing Rewards contract and skips deploying a new one.
WORK_REWARDS_ADDRESS=

# Optional override for staking collector; defaults to Rewards address.
WORK_STAKING_ADDRESS=
