# ECDSA private key for contract deployment account
# (with or without 0x prefix)
HEDERA_PRIVATE_KEY=

# Optional default network used when --network is omitted
# Supported: hardhat | local | testnet | previewnet | mainnet
HEDERA_NETWORK=testnet

# Optional RPC overrides. Defaults are used if left empty.
HEDERA_LOCAL_RPC_URL=http://127.0.0.1:7546
HEDERA_TESTNET_RPC_URL=https://testnet.hashio.io/api
HEDERA_PREVIEWNET_RPC_URL=https://previewnet.hashio.io/api
HEDERA_MAINNET_RPC_URL=https://mainnet.hashio.io/api
