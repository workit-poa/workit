{
  "name": "workit-poa",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "apps/*",
    "examples/*",
    "libs/*"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "dev": "nx run-many -t dev --parallel=2",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "affected:build": "nx affected -t build",
    "affected:test": "nx affected -t test",
    "format": "prettier --write .",
    "graph": "nx graph",
    "demo:kms-hedera": "pnpm --filter @workit-poa/hedera-kms-wallet-demo demo:kms-hedera",
    "hedera:local:start": "bash ./dev/hedera-local-node/manage.sh start",
    "hedera:local:stop": "bash ./dev/hedera-local-node/manage.sh stop",
    "hedera:local:logs": "bash ./dev/hedera-local-node/manage.sh logs",
    "hedera:local:status": "bash ./dev/hedera-local-node/manage.sh status",
    "hedera:local:keys": "bash ./dev/hedera-local-node/manage.sh keys",
    "contracts:ping:local": "pnpm --filter @workit-poa/contracts ping:local",
    "contracts:test:local": "pnpm --filter @workit-poa/contracts test:local",
    "contracts:deploy:local": "pnpm --filter @workit-poa/contracts deploy:local",
    "hedera:hcs:local": "pnpm --filter @workit-poa/contracts hcs:local",
    "hedera:hts:local": "pnpm --filter @workit-poa/contracts hts:local",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate": "drizzle-kit migrate",
    "db:generate:migrate": "pnpm run drizzle:generate && pnpm run drizzle:migrate"
  },
  "devDependencies": {
    "@nx/js": "^21.3.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "drizzle-kit": "^0.30.5",
    "nx": "^21.3.0",
    "prettier": "^3.4.2",
    "tsx": "^4.20.3",
    "typescript": "^5.7.2"
  }
}
